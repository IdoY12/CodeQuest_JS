{
  "name": "backend",
  "version": "1.0.0",
  "description": "CodeQuest JS backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.prisma.json --noEmit",
    "start": "node dist/index.js",
    "prisma:generate": "tsx src/scripts/run-prisma.ts generate",
    "prisma:migrate": "tsx src/scripts/run-prisma.ts migrate dev",
    "prisma:migrate:deploy": "tsx src/scripts/run-prisma.ts migrate deploy",
    "prisma:migrate:reset": "tsx src/scripts/run-prisma.ts migrate reset --force --skip-seed",
    "prisma:seed": "tsx prisma/seed/runMain.ts",
    "test": "echo \"No tests configured yet\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "prisma": {
    "schema": "../packages/db/prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@prisma/client": "^6.19.0",
    "@project/auth-jwt": "file:../packages/auth-jwt",
    "@project/db": "file:../packages/db",
    "@project/exercise-answer": "file:../packages/exercise-answer",
    "@project/user-credentials": "file:../packages/user-credentials",
    "@project/xp-constants": "file:../packages/xp-constants",
    "@project/server-kit": "file:../packages/server-kit",
    "bcrypt": "^6.0.0",
    "config": "^4.4.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "node-cache": "^5.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/config": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
