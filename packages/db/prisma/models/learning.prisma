model LearningPath {
  id          String         @id @default(cuid())
  key         PathType       @unique
  title       String
  description String
  chapters    Chapter[]
  progresses  UserProgress[]
}

model Chapter {
  id          String       @id @default(cuid())
  pathId      String
  title       String
  description String
  orderIndex  Int
  lessons     Lesson[]
  path        LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
}

model Lesson {
  id               String     @id @default(cuid())
  chapterId        String
  title            String
  description      String
  estimatedMinutes Int
  orderIndex       Int
  difficulty       Difficulty
  chapter          Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  exercises        Exercise[]
}

model Exercise {
  id            String                @id @default(cuid())
  lessonId      String
  type          ExerciseType
  prompt        String
  codeSnippet   String
  correctAnswer String
  explanation   String
  orderIndex    Int
  xpReward      Int
  lesson        Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options       ExerciseOption[]
  history       UserExerciseHistory[]
}

model ExerciseOption {
  id         String   @id @default(cuid())
  exerciseId String
  text       String
  isCorrect  Boolean  @default(false)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model DailyPuzzle {
  id              String @id
  prompt          String
  acceptedAnswers Json
  orderIndex      Int    @default(0)
}

model PersonalizedExercise {
  id            String       @id
  level         String
  type          ExerciseType
  prompt        String
  codeSnippet   String
  correctAnswer String
  explanation   String
  xpReward      Int
  orderIndex    Int
  options       Json

  @@index([level])
}
