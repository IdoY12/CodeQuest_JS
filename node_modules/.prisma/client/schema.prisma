model CodePuzzle {
  id              Int      @id @default(autoincrement())
  prompt          String
  acceptedAnswers String[]
  orderIndex      Int      @unique
}

model Exercise {
  id              String           @id @default(cuid())
  experienceLevel ExperienceLevel
  orderIndex      Int
  sectionLabel    String?
  type            ExerciseType
  prompt          String
  codeSnippet     String
  correctAnswer   String
  explanation     String
  options         ExerciseOption[]

  @@index([experienceLevel, orderIndex])
}

model ExerciseOption {
  id         String   @id @default(cuid())
  exerciseId String
  text       String
  isCorrect  Boolean  @default(false)
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model DuelQuestion {
  id            String       @id @default(cuid())
  questionText  String
  codeSnippet   String
  correctAnswer String
  type          ExerciseType
  difficulty    Difficulty
  options       Json?
  explanation   String       @default("")

  @@index([difficulty])
}

model DuelSession {
  id           String    @id @default(cuid())
  player1Id    String
  player2Id    String
  winnerId     String?
  player1Score Int       @default(0)
  player2Score Int       @default(0)
  roundsPlayed Int       @default(0)
  roundReplay  Json?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  player1      User      @relation("Player1Sessions", fields: [player1Id], references: [id], onDelete: Cascade)
  player2      User      @relation("Player2Sessions", fields: [player2Id], references: [id], onDelete: Cascade)
  winner       User?     @relation("WinnerSessions", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([player1Id])
  @@index([player2Id])
}

/// Used by `DuelQuestion.difficulty` (three-band pool: JUNIOR / MID / SENIOR).
enum Difficulty {
  JUNIOR
  MID
  SENIOR
}

enum ExerciseType {
  MCQ
  PUZZLE
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
}

model UserProgress {
  id              String          @id @default(cuid())
  userId          String
  experienceLevel ExperienceLevel

  currentExerciseIndex Int @default(0)

  streakLastActivityDate String?
  streakLastCheckedDate  String?

  practiceLogDateKey             String?
  practiceLogSeconds             Int     @default(0)
  practiceLogIncompleteReminders Int     @default(0)
  practiceLogCompleteSent        Boolean @default(false)

  goal                   String?
  dailyCommitmentMinutes Int?
  notificationsEnabled   Boolean @default(true)
  xpTotal                Int     @default(0)
  level                  Int     @default(1)
  streakCurrent          Int     @default(0)
  user                   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experienceLevel])
  @@index([userId])
}

model User {
  id                    String           @id @default(cuid())
  email                 String           @unique
  username              String
  hashedPassword        String
  avatarUrl             String?
  tokenVersion          Int              @default(0)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  lastActiveAt          DateTime?
  activeExperienceLevel ExperienceLevel?

  progressRows   UserProgress[]
  duelSessionsP1 DuelSession[]  @relation("Player1Sessions")
  duelSessionsP2 DuelSession[]  @relation("Player2Sessions")
  wonSessions    DuelSession[]  @relation("WinnerSessions")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
