model DuelQuestion {
  id            String       @id @default(cuid())
  questionText  String
  codeSnippet   String
  correctAnswer String
  type          ExerciseType
  difficulty    Difficulty
  options       Json?
  explanation   String       @default("")
}

model DuelSession {
  id           String    @id @default(cuid())
  player1Id    String
  player2Id    String
  winnerId     String?
  player1Score Int       @default(0)
  player2Score Int       @default(0)
  roundsPlayed Int       @default(0)
  roundReplay  Json?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  player1      User      @relation("Player1Sessions", fields: [player1Id], references: [id], onDelete: Cascade)
  player2      User      @relation("Player2Sessions", fields: [player2Id], references: [id], onDelete: Cascade)
  winner       User?     @relation("WinnerSessions", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([player1Id])
  @@index([player2Id])
}

model DuelRating {
  id     String @id @default(cuid())
  userId String @unique
  rating Int    @default(1000)
  wins   Int    @default(0)
  losses Int    @default(0)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
