PORT=4000
HOST=0.0.0.0
# Optional: NODE_CONFIG_ENV=docker | compose merges config/docker.json or config/compose.json.
# Match README Docker DB name (codequest_js) or your local Postgres database name.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codequest_js?schema=public
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# CORS: use * for local dev. Production (NODE_ENV=production) requires explicit origins (min 32-char JWT secrets).
# CORS_ORIGIN=https://your.app
# IO_CORS_ORIGIN=https://your.app

# LocalStack (development)
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=questcode-avatars

# Production:
# - set CORS_ORIGIN and IO_CORS_ORIGIN to explicit HTTPS origins (comma-separated for multiple)
# - remove AWS_ENDPOINT; use IAM roles or instance credentials for S3
# - JWT secrets must be at least 32 characters and not placeholder values
