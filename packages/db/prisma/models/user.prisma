model User {
  id                     String            @id @default(cuid())
  email                  String            @unique
  username               String            @unique
  hashedPassword         String?
  googleId               String?           @unique
  avatarUrl              String?
  tokenVersion           Int               @default(0)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  lastActiveAt           DateTime?
  activeExperienceLevel  ExperienceLevel?
  puzzleXpSolveCounts    Json                  @default("{}")

  progressRows    UserProgress[]
  duelSessionsP1  DuelSession[] @relation("Player1Sessions")
  duelSessionsP2  DuelSession[] @relation("Player2Sessions")
  wonSessions     DuelSession[] @relation("WinnerSessions")
}
